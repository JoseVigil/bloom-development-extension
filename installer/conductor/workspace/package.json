{
  "name": "bloom-workspace",
  "productName": "Bloom Workspace",
  "version": "1.0.0",
  "description": "Bloom Nucleus Workspace - Post-installation workspace",
  "main": "main_conductor.js",
  "author": {
    "name": "BTIP Studio",
    "email": "support@btip.studio"
  },
  "license": "MIT",
  "scripts": {
    "prebuild": "node ../shared/bump-version.js",
    "build": "electron-builder --win --x64",
    "build:darwin": "npm run build:darwin:x64 && npm run build:darwin:arm",
    "build:darwin:x64": "electron-builder --mac --x64 -c.directories.output=../../native/bin/darwin_x64/workspace",
    "build:darwin:arm": "electron-builder --mac --arm64 -c.directories.output=../../native/bin/darwin_arm64/workspace",
    "dev": "electron .",
    "dev:darwin": "electron .",
    "version:bump": "node ../shared/bump-version.js",
    "version:patch": "node ../shared/bump-version.js --patch",
    "version:minor": "node ../shared/bump-version.js --minor",
    "version:major": "node ../shared/bump-version.js --major",
    "version:info": "node -e \"const i=require('./build_info.json'); console.log(i.product_name, i.full_version, '|', i.built_at);\""
  },
  "build": {
    "appId": "com.bloom.nucleus.workspace",
    "productName": "Bloom Workspace",
    "executableName": "bloom-workspace",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/bloom.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "bloom-workspace.exe",
      "extraFiles": [
        {
          "from": "bloom-conductor-version.ps1",
          "to": "bloom-conductor-version.ps1"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/bloom.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "artifactName": "bloom-workspace-${arch}.dmg",
      "extraFiles": [
        {
          "from": "../shared/logger.js",
          "to": "shared/logger.js"
        },
        {
          "from": "../shared/global_paths.js",
          "to": "shared/global_paths.js"
        },
        {
          "from": "bloom-conductor-version.sh",
          "to": "bloom-conductor-version.sh"
        }
      ]
    },
    "dmg": {
      "artifactName": "bloom-workspace-${arch}.dmg",
      "sign": false
    },
    "portable": {
      "artifactName": "bloom-workspace.exe"
    },
    "files": [
      "main_conductor.js",
      "onboarding/**/*",
      "core/**/*",
      "assets/**/*",
      "build_info.json",
      "version.json",
      "package.json",
      "bloom-conductor-cli.cmd"
    ],
    "extraFiles": [
      {
        "from": "../shared/logger.js",
        "to": "shared/logger.js"
      },
      {
        "from": "../shared/global_paths.js",
        "to": "shared/global_paths.js"
      }
    ],
    "directories": {
      "output": "../../native/bin/win64/workspace",
      "buildResources": "assets"
    },
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "build_info.json"
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  }
}
