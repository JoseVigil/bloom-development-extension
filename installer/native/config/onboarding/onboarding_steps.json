{
  "_version": "3.0.0",
  "_comment": "SSOT único de steps de onboarding — Bloom Conductor. Consumido por MilestoneRegistry (Main, vía fs) y expuesto al Renderer vía IPC (getStepsConfig). Cualquier cambio de orden, requires o verificación se hace acá, no en onboarding.js.",
  "_changelog": "v3.0.0 (2026-07-10): Migración GitHub App / Device Flow. Retirado el step 'github_auth' (PAT clásico, GITHUB_PAT_DETECTED/GITHUB_TOKEN_STORED). Reemplazado por 'github_app_auth', reordenado DESPUÉS de vault_init (el token de la App se guarda en el Vault — Nucleus debe Authorize() antes de tocar el Keyring real, ver BTIPS-VAULT-MULTIKEY-ANALYSIS.md v1.1 y milestone-registry.js FALLBACK_STEPS). google_auth migrado de GOOGLE_AUTH_COMPLETE (nunca implementado) a ACCOUNT_REGISTERED:google discriminado por 'service'. Este JSON es el SSOT en disco: si diverge del fallback hardcoded de milestone-registry.js, el fallback pierde — sincronizar ambos ante cualquier cambio futuro.",
  "steps": [
    {
      "id": "nucleus_create",
      "view": "workspace",
      "label": "Crear Nucleus",
      "requires": [],
      "produces": "workspace_path",
      "verify": "fs_marker",
      "verifyArgs": {
        "jsonField": "onboarding.workspace_path",
        "markerFile": ".nucleus"
      },
      "blocking": true,
      "cortex_events": [],
      "conductor_reaction": "markStepComplete"
    },
    {
      "id": "vault_init",
      "view": "identity",
      "label": "Inicializar Vault",
      "requires": ["workspace_path"],
      "produces": "vault_initialized",
      "verify": "json_field",
      "verifyArgs": {
        "field": "onboarding.vault_initialized"
      },
      "blocking": true,
      "cortex_events": ["VAULT_INITIALIZED", "VAULT_INIT"],
      "conductor_reaction": "markStepComplete"
    },
    {
      "id": "github_app_auth",
      "view": "identity",
      "label": "Autorizar Batcave (GitHub App)",
      "requires": ["vault_initialized"],
      "produces": "github_app_token",
      "verify": "json_field",
      "verifyArgs": {
        "field": "onboarding.github_app_token"
      },
      "blocking": true,
      "cortex_events": ["GITHUB_APP_AUTHORIZED"],
      "conductor_reaction": "markStepComplete"
    },
    {
      "id": "google_auth",
      "view": "providers",
      "label": "Conectar Google",
      "requires": ["vault_initialized"],
      "produces": "google_account",
      "verify": "json_field",
      "verifyArgs": {
        "field": "onboarding.google_account"
      },
      "blocking": false,
      "cortex_events": ["ACCOUNT_REGISTERED:google"],
      "conductor_reaction": "markStepComplete"
    },
    {
      "id": "ai_provider_setup",
      "view": "providers",
      "label": "Configurar proveedor de IA",
      "requires": ["vault_initialized"],
      "produces": "ai_provider_key",
      "verify": "json_field",
      "verifyArgs": {
        "field": "onboarding.ai_provider_key"
      },
      "blocking": false,
      "cortex_events": ["AI_PROVIDER_CONFIGURED"],
      "conductor_reaction": "markStepComplete"
    },
    {
      "id": "project_create",
      "view": "project",
      "label": "Crear proyecto",
      "requires": ["vault_initialized", "github_app_token"],
      "produces": "project_mandate",
      "verify": "fs_marker",
      "verifyArgs": {
        "jsonField": "onboarding.project_path",
        "markerFile": "genesis.mandate"
      },
      "blocking": true,
      "cortex_events": ["PROJECT_CREATED", "DISCOVERY_COMPLETE"],
      "conductor_reaction": "onOnboardingSuccess"
    }
  ]
}
