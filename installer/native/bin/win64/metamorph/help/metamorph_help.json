[
  {
    "name": "cleanup",
    "use": "cleanup",
    "short": "Clean up staging and old snapshots",
    "category": "MAINTENANCE",
    "example": "  metamorph cleanup\n  metamorph --json cleanup",
    "json_response": "{\"cleaned\": 0, \"freed_bytes\": 0}"
  },
  {
    "name": "generate-manifest",
    "use": "generate-manifest",
    "short": "Generate manifest from current state",
    "category": "RECONCILIATION",
    "example": "  metamorph generate-manifest\n  metamorph --json generate-manifest",
    "json_response": "{\"manifest\": {...}}"
  },
  {
    "name": "info",
    "use": "info",
    "short": "Display detailed system information",
    "category": "SYSTEM",
    "example": "  metamorph info\n  metamorph --json info",
    "json_response": "{\n  \"name\": \"Metamorph\",\n  \"version\": \"1.0.0\",\n  \"build_number\": 2,\n  \"os\": \"darwin\",\n  \"arch\": \"arm64\",\n  \"go_version\": \"go1.22.0\",\n  \"capabilities\": [\"state_inspection\", \"manifest_reconciliation\"],\n  \"paths\": {\n    \"base\":    \"~/Library/BloomNucleus\",\n    \"bin\":     \"~/Library/BloomNucleus/bin\",\n    \"config\":  \"~/Library/BloomNucleus/config\",\n    \"staging\": \"~/Library/BloomNucleus/staging\"\n  }\n}"
  },
  {
    "name": "inspect",
    "use": "inspect",
    "short": "Inspect all binaries (AppData or native build output)",
    "category": "INSPECTION",
    "options": [
      {
        "name": "all",
        "shorthand": "a",
        "usage": "Include external binaries (Temporal, Ollama, Chromium, Node)",
        "default": "false"
      },
      {
        "name": "ion-recipes",
        "usage": "Inspect ion automation recipes",
        "default": "false"
      },
      {
        "name": "native",
        "usage": "Inspect native/bin/<platform>/ build output instead of AppData",
        "default": "false"
      },
      {
        "name": "show-backups",
        "usage": "Show available backup versions (use with --ion-recipes)",
        "default": "false"
      },
      {
        "name": "show-pending",
        "usage": "Show sites with pending status (use with --ion-recipes)",
        "default": "false"
      }
    ],
    "example": "  metamorph inspect\n  metamorph inspect --all\n  metamorph inspect --native\n  metamorph inspect --native --all\n  metamorph --json inspect\n  metamorph --json inspect --native\n  metamorph --json inspect --all",
    "json_response": "{\n  \"managed_binaries\": [\n    {\n      \"name\": \"Brain\",\n      \"version\": \"3.2.0\",\n      \"hash\": \"a3f1c2...\",\n      \"size_bytes\": 18432000,\n      \"last_modified\": \"2026-03-15T14:00:00Z\",\n      \"status\": \"healthy\",\n      \"updatable_by_metamorph\": true\n    }\n  ],\n  \"summary\": {\n    \"total_binaries\": 11,\n    \"managed_count\": 11,\n    \"healthy_count\": 11,\n    \"missing_count\": 0\n  },\n  \"timestamp\": \"2026-03-15T14:16:43Z\"\n}\n\n  Written to (default):  %LOCALAPPDATA%\\\\BloomNucleus\\\\config\\\\metamorph.json\n  Written to (--native): %LOCALAPPDATA%\\\\BloomNucleus\\\\config\\\\native\\\\native_metamorph.json"
  },
  {
    "name": "list",
    "use": "list [source]",
    "short": "List available ion reconciliation manifests",
    "category": "IONPUMP",
    "args": [
      {
        "name": "source",
        "required": false
      }
    ],
    "options": [
      {
        "name": "source",
        "shorthand": "s",
        "usage": "Filter by source: local | remote | all",
        "default": "all"
      }
    ],
    "example": "  metamorph ion-pump list\n  metamorph ion-pump list local\n  metamorph ion-pump list --source remote\n  metamorph --json ion-pump list",
    "json_response": "{\n  \"manifests\": [\n    {\n      \"source\": \"local\",\n      \"path\": \"installer/native/ionpump/bootstrap-ions.json\",\n      \"ions_count\": 1,\n      \"schema_version\": \"2.0\"\n    }\n  ]\n}"
  },
  {
    "name": "reconcile",
    "use": "reconcile",
    "short": "Reconcile installed ions against a manifest",
    "category": "IONPUMP",
    "options": [
      {
        "name": "dry-run",
        "usage": "Simulate reconciliation without writing to ionsites/",
        "default": "false"
      },
      {
        "name": "force-swap",
        "usage": "Bypass Brain signal — for bootstrap/testing without Nucleus",
        "default": "false"
      },
      {
        "name": "manifest",
        "shorthand": "m",
        "usage": "Path to ion reconciliation manifest (required)"
      }
    ],
    "example": "  metamorph ion-pump reconcile --manifest installer/native/ionpump/bootstrap-ions.json --force-swap\n  metamorph ion-pump reconcile --manifest /path/to/batcave-manifest.json\n  metamorph ion-pump reconcile --manifest bootstrap-ions.json --force-swap --dry-run\n  metamorph --json ion-pump reconcile --manifest bootstrap-ions.json --force-swap",
    "json_response": "{\n  \"success\": true,\n  \"manifest\": \"installer/native/ionpump/bootstrap-ions.json\",\n  \"ions_processed\": 1,\n  \"ions_swapped\": 1,\n  \"ions_skipped\": 0,\n  \"ions_failed\": 0,\n  \"force_swap\": true,\n  \"results\": [\n    {\n      \"domain\": \"github.com\",\n      \"status\": \"swapped\",\n      \"version_before\": null,\n      \"version_after\": \"1.0.0\",\n      \"backup_path\": null\n    }\n  ]\n}"
  },
  {
    "name": "rollback",
    "use": "rollback <domain>",
    "short": "Rollback ion site to previous backup version",
    "category": "IONPUMP",
    "args": [
      {
        "name": "<domain>",
        "required": true
      }
    ],
    "options": [
      {
        "name": "force-swap",
        "usage": "Bypass Brain signal — for recovery without Nucleus",
        "default": "false"
      }
    ],
    "example": "  metamorph ion-pump rollback github.com\n  metamorph ion-pump rollback github.com --force-swap\n  metamorph --json ion-pump rollback github.com",
    "json_response": "{\n  \"success\": true,\n  \"domain\": \"github.com\",\n  \"version_before\": \"1.1.0\",\n  \"version_after\": \"1.0.0\",\n  \"backup_consumed\": true\n}"
  },
  {
    "name": "status",
    "use": "status [domain]",
    "short": "Show installed ion site status",
    "category": "IONPUMP",
    "args": [
      {
        "name": "domain",
        "required": false
      }
    ],
    "example": "  metamorph ion-pump status\n  metamorph ion-pump status github.com\n  metamorph --json ion-pump status\n  metamorph --json ion-pump status github.com",
    "json_response": "{\n  \"ionsites_path\": \"C:\\\\Users\\\\user\\\\AppData\\\\Local\\\\BloomNucleus\\\\bin\\\\cortex\\\\ionsites\",\n  \"ions\": [\n    {\n      \"domain\": \"github.com\",\n      \"version\": \"1.0.0\",\n      \"sha256\": \"a3f1c2d4e5b6...\",\n      \"deployed_at\": \"2026-05-15T10:30:00Z\",\n      \"source\": \"bootstrap\",\n      \"has_backup\": false,\n      \"manifest_valid\": true\n    }\n  ]\n}"
  },
  {
    "name": "verify",
    "use": "verify [domain]",
    "short": "Verify SHA-256 integrity of installed ions",
    "category": "IONPUMP",
    "args": [
      {
        "name": "domain",
        "required": false
      }
    ],
    "example": "  metamorph ion-pump verify\n  metamorph ion-pump verify github.com\n  metamorph --json ion-pump verify\n  metamorph --json ion-pump verify github.com",
    "json_response": "{\n  \"valid\": true,\n  \"ions_checked\": 1,\n  \"ions_valid\": 1,\n  \"ions_invalid\": 0,\n  \"results\": [\n    {\n      \"domain\": \"github.com\",\n      \"valid\": true,\n      \"expected_sha256\": \"a3f1c2d4e5b6...\",\n      \"actual_sha256\": \"a3f1c2d4e5b6...\",\n      \"files_checked\": 5\n    }\n  ]\n}"
  },
  {
    "name": "rollback",
    "use": "rollback",
    "short": "Rollback to previous snapshot",
    "category": "ROLLBACK",
    "example": "  metamorph rollback\n  metamorph --json rollback",
    "json_response": "{\"status\": \"success\", \"snapshot\": \"...\"}"
  },
  {
    "name": "rollout",
    "use": "rollout [--only <component>] [--dry-run]",
    "short": "Deploy built binaries from repo to AppData",
    "category": "MAINTENANCE",
    "args": [
      {
        "name": "[--only",
        "required": true
      },
      {
        "name": "<component>]",
        "required": true
      },
      {
        "name": "--dry-run",
        "required": false
      }
    ],
    "options": [
      {
        "name": "dry-run",
        "usage": "Preview what would be copied without making changes",
        "default": "false"
      },
      {
        "name": "only",
        "usage": "Deploy a single component instead of all (brain, nucleus, sentinel, metamorph, host, workspace, setup, sensor, cortex, ionpump, vsix, bootstrap, hooks, config, nssm, ollama, temporal, node, runtime, chrome)"
      }
    ],
    "example": "  metamorph rollout\n  metamorph rollout --dry-run\n  metamorph rollout --only brain\n  metamorph rollout --only ionpump\n  metamorph rollout --only ionpump --dry-run\n  metamorph --json rollout --only nucleus",
    "json_response": "{\n  \"status\": \"success\",\n  \"dry_run\": false,\n  \"only\": \"\",\n  \"repo_root\": \"...\",\n  \"deployed\": [\n    {\"component\": \"Brain\",   \"source\": \"...\", \"destination\": \"...\", \"files_copied\": 1},\n    {\"component\": \"Nucleus\", \"source\": \"...\", \"destination\": \"...\", \"files_copied\": 1}\n  ],\n  \"skipped\": [],\n  \"errors\": []\n}"
  },
  {
