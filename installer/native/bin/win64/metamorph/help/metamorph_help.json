[
  {
    "name": "cleanup",
    "use": "cleanup",
    "short": "Clean up staging and old snapshots",
    "category": "MAINTENANCE",
    "example": "  metamorph cleanup\n  metamorph --json cleanup",
    "json_response": "{\"cleaned\": 0, \"freed_bytes\": 0}"
  },
  {
    "name": "generate-manifest",
    "use": "generate-manifest",
    "short": "Generate manifest from current state",
    "category": "RECONCILIATION",
    "example": "  metamorph generate-manifest\n  metamorph --json generate-manifest",
    "json_response": "{\"manifest\": {...}}"
  },
  {
    "name": "info",
    "use": "info",
    "short": "Display detailed system information",
    "category": "SYSTEM",
    "example": "  metamorph info\n  metamorph --json info",
    "json_response": "{\n  \"name\": \"Metamorph\",\n  \"version\": \"1.0.0\",\n  \"build_number\": 2,\n  \"capabilities\": [\"state_inspection\", \"manifest_reconciliation\"],\n  \"paths\": {...}\n}"
  },
  {
    "name": "inspect",
    "use": "inspect",
    "short": "Inspect all binaries (AppData or native build output)",
    "category": "INSPECTION",
    "options": [
      {
        "name": "all",
        "shorthand": "a",
        "usage": "Include external binaries (Temporal, Ollama, Chromium, Node)",
        "default": "false"
      },
      {
        "name": "native",
        "usage": "Inspect native/bin/\u003cplatform\u003e/ build output instead of AppData",
        "default": "false"
      }
    ],
    "example": "  metamorph inspect\n  metamorph inspect --all\n  metamorph inspect --native\n  metamorph inspect --native --all\n  metamorph --json inspect\n  metamorph --json inspect --native\n  metamorph --json inspect --all",
    "json_response": "{\n  \"managed_binaries\": [\n    {\n      \"name\": \"Brain\",\n      \"version\": \"3.2.0\",\n      \"hash\": \"a3f1c2...\",\n      \"size_bytes\": 18432000,\n      \"last_modified\": \"2026-03-15T14:00:00Z\",\n      \"status\": \"healthy\",\n      \"updatable_by_metamorph\": true\n    }\n  ],\n  \"summary\": {\n    \"total_binaries\": 11,\n    \"managed_count\": 11,\n    \"healthy_count\": 11,\n    \"missing_count\": 0\n  },\n  \"timestamp\": \"2026-03-15T14:16:43Z\"\n}\n\n  Written to (default):  %LOCALAPPDATA%\\\\BloomNucleus\\\\config\\\\metamorph.json\n  Written to (--native): %LOCALAPPDATA%\\\\BloomNucleus\\\\config\\\\native\\\\native_metamorph.json"
  },
  {
    "name": "reconcile",
    "use": "reconcile",
    "short": "Reconcile system against manifest",
    "category": "RECONCILIATION",
    "options": [
      {
        "name": "manifest",
        "shorthand": "m",
        "usage": "Path to manifest file"
      }
    ],
    "example": "  metamorph reconcile --manifest manifest.json\n  metamorph --json reconcile --manifest manifest.json",
    "json_response": "{\"status\": \"success\", \"changes\": []}"
  },
  {
    "name": "rollback",
    "use": "rollback",
    "short": "Rollback to previous snapshot",
    "category": "ROLLBACK",
    "example": "  metamorph rollback\n  metamorph --json rollback",
    "json_response": "{\"status\": \"success\", \"snapshot\": \"...\"}"
  },
  {
    "name": "rollout",
    "use": "rollout [--only \u003ccomponent\u003e] [--dry-run]",
    "short": "Deploy built binaries from repo to AppData",
    "category": "MAINTENANCE",
    "args": [
      {
        "name": "[--only",
        "required": true
      },
      {
        "name": "\u003ccomponent\u003e]",
        "required": true
      },
      {
        "name": "--dry-run",
        "required": false
      }
    ],
    "options": [
      {
        "name": "dry-run",
        "usage": "Preview what would be copied without making changes",
        "default": "false"
      },
      {
        "name": "only",
        "usage": "Deploy a single component instead of all (brain, nucleus, sentinel, metamorph, conductor, setup, host, cortex, nssm, bootstrap, vsix, node)"
      }
    ],
    "example": "  metamorph rollout\n  metamorph rollout --dry-run\n  metamorph rollout --only brain\n  metamorph rollout --only nucleus\n  metamorph rollout --only sentinel\n  metamorph rollout --only metamorph\n  metamorph rollout --only conductor\n  metamorph rollout --only setup\n  metamorph rollout --only host\n  metamorph rollout --only cortex\n  metamorph rollout --only nssm\n  metamorph rollout --only bootstrap\n  metamorph rollout --only vsix\n  metamorph rollout --only node\n  metamorph rollout --only brain --dry-run\n  metamorph --json rollout --only nucleus",
    "json_response": "{\n  \"status\": \"success\",\n  \"dry_run\": false,\n  \"only\": \"\",\n  \"deployed\": [\n    {\"component\": \"Brain\",     \"source\": \"...\", \"destination\": \"...\", \"files_copied\": 12},\n    {\"component\": \"Nucleus\",   \"source\": \"...\", \"destination\": \"...\", \"files_copied\": 4}\n  ],\n  \"skipped\": [],\n  \"errors\": []\n}"
  },
  {
    "name": "status",
    "use": "status",
    "short": "Display current system state",
    "category": "INSPECTION",
    "example": "  metamorph status\n  metamorph --json status",
    "json_response": "{\n  \"timestamp\": \"2026-02-15T10:00:00Z\",\n  \"system_healthy\": true,\n  \"status\": \"operational\",\n  \"summary\": {\n    \"total_binaries\": 7,\n    \"healthy_count\": 7,\n    \"missing_count\": 0\n  }\n}"
  },
  {
    "name": "verify-sync",
    "use": "verify-sync",
    "short": "Verify deployed binaries match the last build",
    "category": "INSPECTION",
    "options": [
      {
        "name": "native",
        "usage": "Verify native/bin/\u003cplatform\u003e/ build output instead of AppData (reads native_metamorph.json)",
        "default": "false"
      }
    ],
    "example": "  metamorph verify-sync\n  metamorph --json verify-sync",
    "json_response": "{\n  \"timestamp\": \"2026-02-27T12:00:00Z\",\n  \"in_sync\": true,\n  \"reference\": \"C:\\\\Users\\\\josev\\\\AppData\\\\Local\\\\BloomNucleus\\\\config\\\\metamorph.json\",\n  \"summary\": {\n    \"total\": 9,\n    \"synced\": 9,\n    \"drifted\": 0,\n    \"missing\": 0\n  },\n  \"components\": [\n    {\n      \"name\": \"Brain\",\n      \"status\": \"synced\",\n      \"expected_hash\": \"b716e2...\",\n      \"actual_hash\":   \"b716e2...\",\n      \"path\": \"C:\\\\Users\\\\josev\\\\AppData\\\\Local\\\\BloomNucleus\\\\bin\\\\brain\\\\brain.exe\"\n    }\n  ]\n}"
  },
  {
    "name": "version",
    "use": "version",
    "short": "Display version and build information",
    "category": "SYSTEM",
    "example": "  metamorph version\n  metamorph --json version",
    "json_response": "{\n  \"name\": \"Metamorph\",\n  \"version\": \"1.0.0\",\n  \"build_number\": 2,\n  \"build_date\": \"2026-02-13\",\n  \"build_time\": \"11:29:00\",\n  \"full_version\": \"v1.0.0-build.2\"\n}"
  }
]
