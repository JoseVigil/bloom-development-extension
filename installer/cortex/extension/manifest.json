{
  "manifest_version": 3,
  "name": "Bloom Nucleus Bridge",
  "version": "3.0.0",
  "description": "Multi-provider AI key management for Bloom",
  "key": "",

  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "activeTab",
    "nativeMessaging",
    "storage",
    "alarms",
    "identity",
    "identity.email",
    "webNavigation",
    "notifications"
  ],

  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://accounts.google.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Synapse Discovery"
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "matches": ["https://github.com/*"],
      "resources": [
        "protocols/discovery.schema.json",
        "protocols/landing.schema.json",
        "protocols/harness.schema.json",
        "protocols/companion.schema.json",
        "discovery.synapse.config.js",
        "landing.synapse.config.js",
        "harness.synapse.config.js",
        "companion.synapse.config.js",
        "discovery/*",
        "discovery/index.html",
        "discovery/styles.css",
        "discovery/discovery.js",
        "discovery/discoveryProtocol.js",
        "discovery/onboarding.js",
        "discovery/script.js",
        "landing/*",
        "landing/index.html",
        "landing/styles.css",
        "landing/landing.js",
        "landing/landingProtocol.js",
        "landing/data-loader.js",
        "landing/script.js",
        "harness/*",
        "harness/index.html",
        "harness/harness.js",
        "harness/harnessProtocol.js",
        "companion/*",
        "companion/index.html",
        "companion/styles.css",
        "companion/companion.js",
        "companion/companionProtocol.js"
      ]
    }
  ],

  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/128x128.png",
    "128": "assets/icon128.png"
  }
}
